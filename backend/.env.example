# Taman Botani Johor — Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=taman_botani

# ─── Server ───────────────────────────────────────────────────
PORT=3001

# ─── Auth ─────────────────────────────────────────────────────
# Secret used to sign/verify staff login tokens (JWT). Change this in production —
# anyone who knows this value can forge a valid staff session.
JWT_SECRET=tbj-dev-secret-change-me

# How long a login session stays valid before requiring re-login.
# Examples: 30m, 8h, 7d
TOKEN_TTL=8h

# Staff login credentials
STAFF_USERNAME=admin
STAFF_PASSWORD=tbj2026
